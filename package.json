{
  "name": "archimedes",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous AI agent platform",
  "scripts": {
    "dev": "cd web && next dev",
    "build": "cd web && next build",
    "lint": "cd web && next lint",
    "typecheck": "cd web && tsc --noEmit",
    "test": "cd web && vitest run",
    "test:watch": "cd web && vitest",
    "desktop:dev": "cd desktop && npm run tauri dev",
    "desktop:build": "cd desktop && npm run tauri build",
    "mobile:sync": "cd mobile && npx cap sync",
    "mobile:android": "cd mobile && npx cap run android",
    "mobile:ios": "cd mobile && npx cap run ios",
    "icons:generate": "node scripts/generate-icons.js"
  },
  "workspaces": [
    "web",
    "desktop",
    "mobile"
  ],
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.59.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.454.0",
    "next": "^15.0.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.8.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^25.0.1",
    "sharp": "^0.35.1",
    "vitest": "^2.1.3"
  },
  "peerDependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-shell": "^2.0.0"
  }
}
