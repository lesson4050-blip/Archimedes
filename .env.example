# ============================================
# Archimedes — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Core Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
ADMIN_API_KEY=change-this-admin-key

# ============================================
# Local LLM (Ollama)
# ============================================
# Current hardware: RTX 3060 12GB / Ryzen 7 5700X / 32GB RAM
# qwen3:14b Q4_K_M fits in 12GB VRAM with full GPU inference
# Upgrade path: qwen3:30b-a3b when RTX 3090 24GB available
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL=qwen3:14b

# ============================================
# Cloud LLM Providers (optional fallback)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=

# Default model router
DEFAULT_MODEL=local

# ============================================
# Database
# ============================================
SQLITE_PATH=./data/archimedes.db
CHROMA_PATH=./data/chroma_db

# ============================================
# Security
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:1420
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=120

# ============================================
# Frontend
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ============================================
# Phase 5: Tool System
# ============================================
TAVILY_API_KEY=tvly-...  # Get from app.tavily.com

